# Python-generated files
__pycache__/
*.py[oc]
build/
dist/
wheels/
*.egg-info

# Virtual environments
.venv

# Claude Code local settings (machine-specific only — global rules tracked in .claude/rules/)
.claude/settings.local.json

# GitHub Actions (run via separate config)
.github/

# Environment / secrets
.env

# GPU cloud runner scripts (private, provider-specific)
scripts/*/modal_*.py

# launchd / cron plists are per-machine and should not be checked in
scripts/*/*.plist

# Competition results
results/
results-temp/

# Optimizer logs and CMA output (but keep daily status tracking)
logs/*
!logs/status/
outcmaes/

# Workbench symlink
.mb

# Large result files
*.npy

# raw/ — local cache of native-format originals (PDFs, transcripts, etc.).
# source/ holds the in-git distillations; raw is regenerable from source frontmatter.
raw/
