# Python-generated files
__pycache__/
*.py[oc]
build/
dist/
wheels/
*.egg-info

# Virtual environments
.venv

# Claude Code local settings (machine-specific only — global rules tracked in .claude/rules/)
.claude/settings.local.json

# Environment / secrets
.env

# GPU cloud runner scripts (private, provider-specific)
scripts/*/modal_*.py

# launchd / cron plists are per-machine and should not be checked in
scripts/*/*.plist

# Competition results
results/
results-temp/

# Optimizer logs and CMA output (status telemetry now lives in mb/logs/)
logs/
outcmaes/

# Workbench symlink
.mb

# Large result files
*.npy

# docs/raw/ — local cache of native-format originals (PDFs, transcripts, etc.).
# docs/source/ holds the in-git distillations; docs/raw is regenerable from source frontmatter.
docs/raw/
.obsidian/
