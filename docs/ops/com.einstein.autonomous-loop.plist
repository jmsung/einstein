<?xml version="1.0" encoding="UTF-8"?>
<!-- macOS launchd template. Replace __PROJECT_ROOT__ (cb checkout) and __HOME__
     (the user home holding ~/.claude auth) before installing. See docs/ops/README.md. -->
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.einstein.autonomous-loop</string>

  <!-- Phase 3 entry point: scheduled_cycle.py wraps
       autonomous_loop.py (the one-problem, by-priority flags) and adds the runs/day
       cap + 7200s hard timeout + run ledger. Do NOT call autonomous_loop.py
       directly here; the pre-Phase-3 command lacked the by-priority flag and ground P1. -->
  <key>ProgramArguments</key>
  <array>
    <string>/bin/bash</string>
    <string>-lc</string>
    <string>cd "__PROJECT_ROOT__" &amp;&amp; uv run python scripts/scheduled_cycle.py --skip-if-recent 20 --max-runs-per-day 48</string>
  </array>

  <key>WorkingDirectory</key>
  <string>__PROJECT_ROOT__</string>

  <!-- 30-min cadence, push-hard mode: each cycle is ~15 min (housekeeping-bound),
       so 30m + the lockfile = effectively continuous with no overlap. 48/day cap
       is a backstop; the real ceiling is the 5M-token/day budget + the Pro/Max
       subscription usage window (shared with interactive use — expect to hit the
       rolling limit, at which point claude -p falls back to mechanical until it resets). -->
  <key>StartInterval</key>
  <integer>1800</integer>

  <key>RunAtLoad</key>
  <true/>

  <key>StandardOutPath</key>
  <string>__PROJECT_ROOT__/../mb/logs/scheduler.log</string>

  <key>StandardErrorPath</key>
  <string>__PROJECT_ROOT__/../mb/logs/scheduler.err.log</string>

  <!-- launchd starts with a bare environment. HOME is REQUIRED so the headless
       `claude -p` inner agent finds its auth under ~/.claude; without it every
       LLM cycle silently degrades to the mechanical path. -->
  <key>EnvironmentVariables</key>
  <dict>
    <key>HOME</key>
    <string>__HOME__</string>
    <key>PATH</key>
    <string>/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin</string>
  </dict>

  <key>ThrottleInterval</key>
  <integer>60</integer>
</dict>
</plist>
